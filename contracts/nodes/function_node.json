{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "nodes/function_node",
  "title": "FunctionNode",
  "type": "object",
  "required": ["stable_id", "node_hash", "type", "name", "qualified_name", "signature", "docstring", "body", "file_path", "line_start", "line_end", "language", "repo", "active", "embed_text", "provenance", "source"],
  "additionalProperties": false,
  "properties": {
    "stable_id":       { "type": "string" },
    "node_hash":       { "type": "string" },
    "type":            { "type": "string", "const": "function" },
    "name":            { "type": "string" },
    "qualified_name":  { "type": "string" },
    "signature":       { "type": "string" },
    "docstring":       { "type": "string" },
    "body":            { "type": "string" },
    "file_path":       { "type": "string" },
    "line_start":      { "type": "integer" },
    "line_end":        { "type": "integer" },
    "language":        { "type": "string" },
    "repo":            { "type": "string" },
    "active":          { "type": "boolean" },
    "embed_text":      { "type": "string" },
    "provenance":      { "type": "string", "enum": ["static", "dynamic", "confirmed", "conflict"] },
    "source":          { "type": "string", "enum": ["static", "dynamic", "confirmed", "conflict"] },
    "observed_calls":  { "type": "integer" },
    "avg_latency_ms":  { "type": "number" },
    "branch_coverage": { "type": "number" }
  }
}
