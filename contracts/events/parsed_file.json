{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "events/parsed_file",
  "title": "ParsedFile",
  "type": "object",
  "required": ["file_path", "language", "repo", "commit_sha", "nodes", "intra_file_edges"],
  "additionalProperties": false,
  "properties": {
    "file_path":        { "type": "string" },
    "language":         { "type": "string" },
    "repo":             { "type": "string" },
    "commit_sha":       { "type": "string" },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stable_id", "node_hash", "type", "name", "signature", "docstring", "body", "line_start", "line_end"],
        "additionalProperties": false,
        "properties": {
          "stable_id":  { "type": "string" },
          "node_hash":  { "type": "string" },
          "type":       { "type": "string" },
          "name":       { "type": "string" },
          "signature":  { "type": "string" },
          "docstring":  { "type": "string" },
          "body":       { "type": "string" },
          "line_start": { "type": "integer" },
          "line_end":   { "type": "integer" },
          "parent_id":  { "type": "string" }
        }
      }
    },
    "intra_file_edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_stable_id", "target_stable_id", "type"],
        "additionalProperties": false,
        "properties": {
          "source_stable_id": { "type": "string" },
          "target_stable_id": { "type": "string" },
          "type": { "type": "string", "enum": ["CALLS", "IMPORTS", "DEFINES"] }
        }
      }
    }
  }
}
