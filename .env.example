REPOS_DIR=~/workspaces                # directory containing your git repos
NEO4J_PASSWORD=localpassword          # required — services fail without this
POSTGRES_PASSWORD=localpassword       # required — used in POSTGRES_DSN and postgres container
ALLOWED_REPO_ROOTS=/repos             # comma-separated allowed base dirs for repo-watcher
LLM_MODEL=qwen2.5-coder:7b
VOYAGE_API_KEY=                       # optional, leave blank to use local embeddings
